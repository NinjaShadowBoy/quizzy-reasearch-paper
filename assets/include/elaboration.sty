\newcommand{\emptyspaces}[1]{%
 \setcounter{tempctr}{0}%
 \whiledo{\not \value{tempctr} > #1}{%
  \phantom{x}%
  \stepcounter{tempctr}%
 }%
}

\definecolor{beispielfarbe}{rgb}{1.0,1.0,0.888}

\newfloat{fbeispiel}{tbhp}{bsp}
\floatname{fbeispiel}{Example}

%% Fügt ein Beispiel ein
%%   #1: Text des Beispiels
%%   #2: Unterschrift
%%   #3: Label
\newcommand{\beispiel}[3]{%
 \stepcounter{beispielnummer}%
 \begin{fbeispiel}
  \begin{center}\colorbox{beispielfarbe}{%
    \parbox{0.9\textwidth}{%
     #1%
    }}%\\\vskip 0.2cm%
   %%Bsp. \arabic{beispielnummer}: #2%
  \end{center}%
  \caption{#2}
  \label{#3}
 \end{fbeispiel}
}

%% Fügt ein Beispiel ein
%%   #1: Text des Beispiels
%%   #2: Unterschrift
%%   #3: Label
\newcommand{\pbeispiel}[4]{%
 \stepcounter{beispielnummer}%
 \begin{fbeispiel}[#4]
  \begin{center}\colorbox{beispielfarbe}{%
    \parbox{0.9\textwidth}{%
     #1%
    }}%\\\vskip 0.2cm%
   %%Bsp. \arabic{beispielnummer}: #2%
  \end{center}%
  \caption{#2}
  \label{#3}
 \end{fbeispiel}
}

\newcommand{\nfbeispiel}[1]{%
 \begin{center}\colorbox{beispielfarbe}{%
   \parbox{0.9\textwidth}{%
    #1%
   }}%
 \end{center}%
}


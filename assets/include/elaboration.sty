\newcommand{\mytitle}{%
 \thispagestyle{empty}%
 %    
 \null\vfil%
 \begin{center}%
  \includegraphics[height=10cm]{assets/img/256px-Saint-Jean-Logo.png}%
  \vskip 5cm%
   {\large \textbf{Course: Research Methodology} \par}%
  \vskip 1cm%
   {\textbf{\Large \MyThema} \par}%
  \vskip 1.5cm%
    {\Large \MyAuthor \par}%
    \ifthenelse{\equal{\MyCoAuthors}{}}{}{%
     \vskip 0.5cm%
     {\normalsize \MyCoAuthors \par}%
    }%
  \small{Student ID: \MyMatrikel} \\%
  \small{\textit{\today{}}}%
 \end{center}%
 \vfil\null%
}

